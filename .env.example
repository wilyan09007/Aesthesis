# Aesthesis — environment variables
#
# Copy to `.env` and fill in. `.env` is gitignored.
# The apps don't auto-load .env — source it before running, e.g.
#   set -a; source .env; set +a
# or run via `dotenv -- uvicorn ...`.
#
# All keys below are required to run the app or the tests. There is no
# mock mode — tests hit the real TRIBE GPU service and the real Gemini API.

# ──────────────────────────────────────────────────────────────────────────────
# Aesthesis app  (aesthesis_app/aesthesis/config.py)
# ──────────────────────────────────────────────────────────────────────────────

# Required. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required. Where the app POSTs videos.
# Local dev (TRIBE container on the same machine): http://localhost:8001
# Prod: https://<org>--aesthesis-tribe-process-video-timeline.modal.run
TRIBE_SERVICE_URL=http://localhost:8001
TRIBE_REQUEST_TIMEOUT_S=300

# Gemini model selection (defaults shown)
GEMINI_MODEL_INSIGHTS=gemini-2.0-flash
GEMINI_MODEL_VERDICT=gemini-2.0-flash

# Upload handling
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=52428800   # 50 MB
MAX_DURATION_S=30
MAX_WIDTH=1920
MAX_HEIGHT=1080
CLEANUP_UPLOADS=1

# CORS — origins allowed to call /api/analyze from the browser.
# Defaults cover the Next.js dev server (npm run dev → :3000).
# In prod set this to the deployed frontend origin (no trailing slash).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────────────────────
# Phase 2 capture pipeline  (DESIGN.md §§4.1, 4.2, 4.2b)
# Set when running the URL → BrowserUse → live frames + MP4 → analyze flow.
# Reuses GEMINI_API_KEY above for the BrowserUse LLM (langchain-google-genai).
# All values shown are the in-code defaults — uncomment to override.
# ──────────────────────────────────────────────────────────────────────────────

# Chromium headless mode for the BrowserUse subprocess.
# 1 = headless (default, works on CI / headless servers).
# 0 = headed (visual debugging, REQUIRES a desktop session — Linux X11 / macOS / Windows desktop).
# CHROMIUM_HEADLESS=1

# Gemini model BrowserUse uses to pick actions (vision-capable required).
# Default: gemini-2.5-pro (better action accuracy than Flash on complex pages).
# Override examples: gemini-2.5-flash (cheaper/faster), gemini-2.0-flash-exp.
# BROWSERUSE_MODEL=gemini-2.5-pro

# D1 hard wall-clock cap for the entire capture subprocess (Chromium launch
# + nav + agent.run + ffmpeg encode + cleanup). Parent SIGKILLs after this.
# Tune up if you regularly need longer captures; tune down for tighter
# stage-day demos.
# CAPTURE_MAX_WALL_S=90

# D7 inner cap on CDP screencast duration. Subprocess stops the screencast
# and finalizes the MP4 after this many seconds even if BrowserUse hasn't
# returned. Wall-clock above is the outer safety net.
# CAPTURE_RECORDING_CAP_S=30

# Chromium viewport for the captured tab. 1280x720 renders most modern
# sites correctly; bump for sites that detect mobile at narrower widths.
# CAPTURE_VIEWPORT_WIDTH=1280
# CAPTURE_VIEWPORT_HEIGHT=720

# D29 stage-day fallback directory. GET /api/cached-demos enumerates MP4s
# in this directory (driven by MANIFEST.json -> [{url, label, mp4_filename}]).
# Frontend offers a "Use cached demo" button on capture_failed when the
# requested URL matches a manifest entry.
# CACHED_DEMOS_DIR=./aesthesis_app/cached_demos

# Optional alias — langchain-google-genai falls back to GOOGLE_API_KEY if
# GEMINI_API_KEY isn't picked up. browser_agent.py reads GEMINI_API_KEY
# first then GOOGLE_API_KEY. Set whichever is convenient.
# GOOGLE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# TRIBE service  (tribe_service/tribe_neural/*)
#
# When deployed on Modal these are container-side; set them via the Modal
# function definition or `modal secret create`, not this file.
# When running locally (uvicorn tribe_neural.api:app), put them here.
# ──────────────────────────────────────────────────────────────────────────────

TRIBE_DATA_DIR=./data
TRIBE_UPLOAD_DIR=     # default: system temp dir

# Worker / queue
GPU_WORKER_MAX_JOBS=1
TRIBE_JOB_TIMEOUT=300
REDIS_HOST=localhost
REDIS_PORT=6379

# Edge-TR trimming (leave 0 unless debugging)
EDGE_TR_TRIM_DISABLE=0

# ──────────────────────────────────────────────────────────────────────────────
# Modal secrets (NOT loaded from this file — set via `modal secret create`)
# ──────────────────────────────────────────────────────────────────────────────
#
# Optional — only needed if HuggingFace rate-limits anonymous downloads of
# V-JEPA 2 / DINOv2 / Wav2Vec-BERT / LLaMA 3.2 weights on first model load.
#
#   modal secret create huggingface-token HF_TOKEN=hf_xxx
#
# HF_TOKEN=hf_xxx

# ──────────────────────────────────────────────────────────────────────────────
# Logging (both services)
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text      # text | json

# ──────────────────────────────────────────────────────────────────────────────
# Frontend  (aesthesis-app/, Next.js)
#
# These get inlined at `next build` time into the browser bundle. Put them
# in aesthesis-app/.env.local for development. They cannot be changed at
# runtime — rebuild after editing.
# ──────────────────────────────────────────────────────────────────────────────

# Where the browser POSTs to /api/analyze. Must match where uvicorn is
# bound. Default below targets the local backend on :8000.
NEXT_PUBLIC_AESTHESIS_API_URL=http://localhost:8000
